rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for auth and RBAC check
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }

    function getUserCompanyID() {
      return getUserData().companyId;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isCompanyOwner() {
      return isAuthenticated() && getUserRole() == 'company_owner';
    }

    function isExportManager() {
      return isAuthenticated() && getUserRole() == 'export_manager';
    }

    function isFinanceStaff() {
      return isAuthenticated() && getUserRole() == 'finance_staff';
    }

    function isCompanyMember(companyId) {
      return isAuthenticated() && (
        getUserCompanyID() == companyId || 
        getUserData().companyId == companyId
      );
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || (isCompanyOwner() && resource.data.companyId == getUserCompanyID()));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || (isCompanyOwner() && resource.data.companyId == getUserCompanyID() && request.resource.data.role != 'admin'));
      allow delete: if isAdmin() || (isCompanyOwner() && resource.data.companyId == getUserCompanyID());
    }

    // --- Companies Collection ---
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (isCompanyMember(companyId) || resource.data.applicantUserId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && getUserRole() == 'guest';
      allow update, delete: if isAdmin() || (isCompanyOwner() && isCompanyMember(companyId));
    }

    // --- Invitations Collection ---
    match /invitations/{invitationId} {
      // Preview needs public read if they have a valid token
      allow read: if (isAuthenticated() && (isCompanyOwner() && resource.data.companyId == getUserCompanyID())) || 
                  (request.query.token == resource.data.token && resource.data.status == 'pending');
      allow create, update, delete: if isCompanyOwner() || isAdmin();
    }

    // --- Export Cases Collection ---
    match /export_cases/{caseId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow create: if isAuthenticated() && (isExportManager() || isAdmin());
      allow update, delete: if isAuthenticated() && (isExportManager() || isAdmin()) && isCompanyMember(resource.data.companyId);
    }

    // --- Cost Data Collection ---
    match /cost_data/{caseId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow create, update, delete: if isAuthenticated() && (isExportManager() || isFinanceStaff() || isAdmin()) && isCompanyMember(resource.data.companyId);
    }

    // --- Pricing Results Collection ---
    match /pricing_results/{caseId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow create, update, delete: if isAuthenticated() && (isExportManager() || isAdmin()) && isCompanyMember(resource.data.companyId);
    }

    // --- Financial Analysis Collection ---
    match /financial_analysis/{caseId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow create, update, delete: if isAuthenticated() && (isFinanceStaff() || isAdmin()) && isCompanyMember(resource.data.companyId);
    }

    // --- Scenarios Collection ---
    match /scenarios/{scenarioId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow create, update, delete: if isAuthenticated() && (isExportManager() || isAdmin()) && isCompanyMember(request.resource.data.companyId);
    }

    // --- Risk Assessments Collection ---
    match /risk_assessments/{caseId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow write: if isAdmin(); // Risk is auto-generated by the backend system
    }

    // --- AI Recommendations Collection ---
    match /advisor_recommendations/{caseId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow write: if isAdmin(); // Written exclusively by server backend system
    }

    // --- Generated Documents Collection ---
    match /documents/{documentId} {
      allow read: if isAuthenticated() && (isCompanyMember(resource.data.companyId) || isAdmin());
      allow create, update, delete: if isAuthenticated() && (isExportManager() || isCompanyOwner() || isAdmin()) && isCompanyMember(request.resource.data.companyId);
    }

    // --- Audit Logs Collection ---
    match /audit_logs/{logId} {
      allow read, write: if isAdmin(); // Exclusively for platform administrators and system audit
    }
  }
}
